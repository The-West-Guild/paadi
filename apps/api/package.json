    "@paadi/eslint-config": "workspace:*",
    "@paadi/typescript-config": "workspace:*",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.10.0",
    "@types/supertest": "^7.2.0",
    "dotenv": "^16.4.7",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "catalog:"
  }
