# Base URL of the Paadi API the MCP server talks to.
PAADI_BASE_URL=http://localhost:3001

# API key minted from POST /me/api-keys (starts with pk_live_ or pk_test_).
# The key's scopes decide which tools are exposed. Shown once at mint time.
PAADI_API_KEY=

# Optional comma-separated scope fallback, used only when the server cannot
# probe the key's scopes (e.g. GET /me/api-keys/current is unavailable).
# Example: pots:read,pots:write,wallet:read
PAADI_MCP_SCOPES=

# Optional 4-digit transaction PIN. Setting it enables the money-moving tools
# (pay_split_from_wallet, withdraw). Leave blank to keep them disabled.
PAADI_PIN=
