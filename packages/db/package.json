{
  "name": "@paadi/db",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "build": "prisma generate && tsc",
    "check-types": "prisma generate && tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@prisma/client": "^6.3.0"
  },
  "devDependencies": {
    "@paadi/eslint-config": "workspace:*",
    "@paadi/typescript-config": "workspace:*",
    "eslint": "^9.17.0",
    "prisma": "^6.3.0",
    "typescript": "catalog:"
  }
}
